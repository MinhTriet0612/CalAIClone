// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String

  // Profile relation
  profile   Profile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Bio Metrics
  age             Int?
  birthDate       DateTime?
  gender          String? // "male" | "female" | "other"
  height          Float? // cm
  weight          Float? // kg
  activityLevel   String? // "sedentary" | "light" | "moderate" | "active" | "very_active"
  workoutsPerWeek Int?
  goal            String? // "weight_loss" | "muscle_gain" | "maintenance" | "cutting" | "health"
  targetWeight    Float?

  // Relations
  meals         Meal[]
  targetPeriods TargetPeriod[]
  weightLogs    WeightLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profiles")
}

model WeightLog {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  rawWeight   Float // Scale weight entered by user
  trendWeight Float // EMA smoothed weight

  createdAt DateTime @default(now())

  @@index([profileId, createdAt])
  @@map("weight_logs")
}

model TargetPeriod {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  startDate DateTime // Start of the period (normalized to UTC 00:00:00)
  endDate   DateTime? // End of the period (NULL means it's the currently active plan)

  calories Int
  protein  Float
  carbs    Float
  fats     Float
  goal     String? // Keep track of what the goal was during this period

  createdAt DateTime @default(now())

  @@index([profileId, startDate, endDate])
  @@map("target_periods")
}

model Meal {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  name        String
  foodItems   String[]
  calories    Float
  protein     Float
  carbs       Float
  fats        Float
  imageUrl    String?
  healthScore Int? // Health score from 1-10 (optional, can be calculated or set manually)

  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId, date])
  @@map("meals")
}
